# --- Database: Supabase Postgres (shared provider with Drip League FF) ---
# Pooled connection for the app (Supabase "Transaction" pooler, port 6543):
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for migrations (port 5432):
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
# Set BOTH to enable Supabase Auth (same project as Drip = shared accounts).
# Leave unset for the self-contained local JWT auth driver (dev/CI/tests).
# NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon key>"

# Used by the local JWT auth driver. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me"

# Protects /api/cron/sync (the GitHub Actions "Sync results" workflow sends
# it as a Bearer token). Generate with: openssl rand -hex 32
CRON_SECRET="change-me"

# Optional: enables GIF search in league chat. Free key from
# https://developers.giphy.com — leave unset to hide the GIF button.
# (TENOR_API_KEY also works for grandfathered Tenor keys; Google stopped
# accepting new Tenor API clients in Jan 2026.)
# GIPHY_API_KEY=""
# Comma-separated emails that are ALWAYS super admins (cannot be revoked
# from the HQ page). Defaults to the founder account if unset.
# SUPER_ADMIN_EMAILS="mlporritt@gmail.com"

# Optional: enables invite emails, commissioner nudges, and automated
# deadline reminders. Preferred driver: Google Workspace SMTP (the provider
# already used for Drip) — SMTP_USER is a Workspace address, SMTP_PASS is an
# app password from myaccount.google.com/apppasswords (requires 2FA).
# SMTP_USER="commish@epicpickem.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# EMAIL_FROM="Epic Pick'em <commish@epicpickem.com>"
# Alternative driver: Resend (domain must be verified in their dashboard).
# RESEND_API_KEY=""
# Absolute base URL used in email links (staging/prod set this per app).
# APP_URL="https://epicpickem.com"
