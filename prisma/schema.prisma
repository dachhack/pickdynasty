// Epic Pick'em (epicpickem.com) data model.
// Postgres (Supabase) — shared provider stack with Drip League FF.
// DATABASE_URL: pooled connection (port 6543, ?pgbouncer=true)
// DIRECT_URL:   direct connection (port 5432) used by migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  // With Supabase Auth this is the auth.users UUID (shared account across
  // Drip + Epic); with the local dev auth driver it's a generated cuid.
  id           String       @id @default(cuid())
  email        String       @unique
  // Only set by the local dev auth driver; Supabase Auth users have none.
  passwordHash String?
  name         String
  // Site-wide operator role — see src/lib/superadmin.ts (SUPER_ADMIN_EMAILS
  // env grants it regardless of this flag).
  isSuperAdmin Boolean      @default(false)
  // Opted out of reminder/nudge emails (via the unsubscribe link).
  emailOptOut  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  memberships  Membership[]
  leagues      League[]     @relation("LeagueCreator")
}

model League {
  id          String       @id @default(cuid())
  name        String
  sport       String // one of SPORTS in src/lib/sports.ts
  season      String // e.g. "2026"
  inviteCode  String       @unique
  // classic | confidence | survivor | spread — see src/lib/formats.ts
  format      String       @default("classic")
  // Blind picks: other players' picks stay hidden until each game locks.
  blindPicks  Boolean      @default(true)
  // Commissioner may view hidden picks (for dispute resolution).
  adminCanSeePicks Boolean @default(false)
  buyIn       Float        @default(0)
  currency    String       @default("USD")
  createdById String
  createdBy   User         @relation("LeagueCreator", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())
  memberships Membership[]
  slates      Slate[]
  moneyEntries MoneyEntry[]
  fantasyLink FantasyLink?
  messages    Message[]
}

// Connects a pick'em league to a Sleeper or ESPN fantasy league so
// commissioners can import weekly head-to-head matchups as pick'em games.
model FantasyLink {
  id               String  @id @default(cuid())
  leagueId         String  @unique
  provider         String // sleeper | espn
  providerLeagueId String
  season           String
  name             String  @default("")
  // ESPN private leagues require these cookies; public leagues don't.
  espnS2           String?
  swid             String?
  league           League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  leagueId  String
  role      String   @default("PLAYER") // COMMISSIONER | PLAYER
  teamName  String
  teamColor String   @default("#4f46e5")
  teamEmoji String   @default("🏆")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  picks     Pick[]
  moneyEntries MoneyEntry[]
  tiebreakers TiebreakerGuess[]
  reactions Reaction[]
  messages  Message[]
  messageReactions MessageReaction[]
  reminderLogs ReminderLog[]

  @@unique([userId, leagueId])
}

// A slate is a round of games players pick against: an NFL week,
// a day of March Madness, a tennis round, etc.
model Slate {
  id           String    @id @default(cuid())
  leagueId     String
  name         String // "Week 1", "Sweet 16", "Wimbledon QF"
  order        Int       @default(0)
  // Optional slate-wide deadline; games also lock individually at start time.
  pickDeadline DateTime?
  league       League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  games        Game[]
  tiebreakers  TiebreakerGuess[]
  reactions    Reaction[]
  reminderLogs ReminderLog[]
  createdAt    DateTime  @default(now())
}

model Game {
  id        String    @id @default(cuid())
  slateId   String
  homeTeam  String
  awayTeam  String
  startTime DateTime
  // null = not decided; HOME | AWAY | TIE.
  // In spread leagues this is the AGAINST-THE-SPREAD result, not the SU winner.
  winner    String?
  // Live/final score, updated by result sync while games are in progress.
  homeScore Int?
  awayScore Int?
  // Point spread from the HOME team's perspective (e.g. -3.5 = home favored),
  // imported from ESPN odds. Only used by spread-format leagues.
  spread    Float?
  // ESPN event id when the game was imported — enables automatic result sync.
  externalId String?
  // Sport this game was imported from, when it differs from the league's
  // primary sport (null = league.sport). Lets one league mix NFL Sundays
  // with MLB series etc.; sync fetches the right scoreboard per game.
  sport     String?
  slate     Slate     @relation(fields: [slateId], references: [id], onDelete: Cascade)
  picks     Pick[]
  createdAt DateTime  @default(now())
}

model Pick {
  id           String     @id @default(cuid())
  gameId       String
  membershipId String
  choice       String // HOME | AWAY
  // Confidence-format rank: 1 (least sure) .. N games (most sure).
  confidence   Int?
  updatedAt    DateTime   @updatedAt
  game         Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([gameId, membershipId])
}

// League chat: text and/or a GIF per message. Polling MVP — swap the feed
// for Supabase Realtime when the production project is wired up.
model Message {
  id           String            @id @default(cuid())
  leagueId     String
  membershipId String? // kept nullable so messages survive member removal
  body         String            @default("")
  gifUrl       String?
  createdAt    DateTime          @default(now())
  league       League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  membership   Membership?       @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  reactions    MessageReaction[]

  @@index([leagueId, createdAt])
}

model MessageReaction {
  id           String     @id @default(cuid())
  messageId    String
  membershipId String
  emoji        String
  message      Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([messageId, membershipId, emoji])
}

// Hand-curated pick packs, built by super admins in HQ and published
// platform-wide as one-tap game bundles in the slate builder.
model PickPack {
  id          String         @id @default(cuid())
  title       String
  emoji       String         @default("🎁")
  description String         @default("")
  published   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  games       PickPackGame[]
}

model PickPackGame {
  id         String   @id @default(cuid())
  packId     String
  sport      String
  externalId String?
  homeTeam   String
  awayTeam   String
  startTime  DateTime
  winner     String?
  homeScore  Int?
  awayScore  Int?
  spread     Float?
  pack       PickPack @relation(fields: [packId], references: [id], onDelete: Cascade)
}

// One automated deadline reminder per member per slate — the cron endpoint
// checks this before emailing so nobody gets nagged twice.
model ReminderLog {
  id           String     @id @default(cuid())
  slateId      String
  membershipId String
  createdAt    DateTime   @default(now())
  slate        Slate      @relation(fields: [slateId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([slateId, membershipId])
}

// One-tap emoji reactions on a slate's recap (🔥😂💀🎯). Toggled on/off.
model Reaction {
  id           String     @id @default(cuid())
  slateId      String
  membershipId String
  emoji        String
  createdAt    DateTime   @default(now())
  slate        Slate      @relation(fields: [slateId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([slateId, membershipId, emoji])
}

// Tiebreaker: each member predicts the total combined points of the slate's
// last-starting game. Closest guess wins ties on that slate.
model TiebreakerGuess {
  id           String     @id @default(cuid())
  slateId      String
  membershipId String
  value        Int
  slate        Slate      @relation(fields: [slateId], references: [id], onDelete: Cascade)
  membership   Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([slateId, membershipId])
}

// Money tracker only — no payment processing. Positive amounts are money
// into the pot (buy-ins); negative are money out (payouts).
model MoneyEntry {
  id           String      @id @default(cuid())
  leagueId     String
  membershipId String?
  type         String // BUY_IN | PAYOUT | ADJUSTMENT
  amount       Float
  note         String      @default("")
  settled      Boolean     @default(false) // has the cash actually changed hands?
  createdAt    DateTime    @default(now())
  league       League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  membership   Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)
}
